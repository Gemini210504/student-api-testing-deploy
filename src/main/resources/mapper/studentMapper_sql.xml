<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.testing_first.demo.mapper.StudentMapper">

    <!-- ✅ Result Mapping -->
    <resultMap id="StudentResultMap" type="com.testing_first.demo.model.Student">
        <id     property="id"              column="id"/>
        <result property="numberIdentify"  column="number_identify"/>
        <result property="name"            column="name"/>
        <result property="gender"          column="gender"/>
        <result property="email"           column="email"/>
        <result property="status"          column="status"/>
        <result property="createdAt"       column="created_at"/>
        <result property="updatedAt"       column="updated_at"/>
    </resultMap>

    <!-- ✅ Select All -->
    <select id="findAll" resultMap="StudentResultMap">
        SELECT * FROM students
        ORDER BY number_identify
    </select>

    <!-- ✅ Select By ID -->
    <select id="findById" parameterType="java.util.UUID" resultMap="StudentResultMap">
        SELECT * FROM students
        WHERE id = #{id}
    </select>

    <!-- ✅ Insert -->
    <insert id="create" parameterType="com.testing_first.demo.dto.request.StudentCreateRequest">
        INSERT INTO students (name, gender, email, status)
        VALUES (#{name}, #{gender}, #{email}, #{status})
    </insert>

    <!-- ✅ Update -->
    <update id="update" parameterType="com.testing_first.demo.model.Student">
        UPDATE students
        SET
            name = #{name},
            gender = #{gender},
            email = #{email},
            status = #{status},
            updated_at = CURRENT_TIMESTAMP
        WHERE id = #{id}
    </update>

    <!-- ✅ Delete -->
    <delete id="deleteById" parameterType="java.util.UUID">
        DELETE FROM students
        WHERE id = #{id}
    </delete>

</mapper>